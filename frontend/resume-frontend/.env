# ── OLLAMA — disabled (not required when using Groq) ─────────────────────────
# Leave OLLAMA_HOST unset. The LLM waterfall will skip Ollama automatically.
# Embeddings will fall back to sentence-transformers (all-MiniLM-L6-v2).

# ── APP ───────────────────────────────────────────────────────────────────────
APP_NAME=Career Genie AI
DEPLOYMENT_MODE=development
LOG_LEVEL=INFO

# ── GROQ MODELS ───────────────────────────────────────────────────────────────
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_SMART_MODEL=llama-3.3-70b-versatile

# ── VECTOR DB ─────────────────────────────────────────────────────────────────
# Defaults to backend/chroma_db — change if you want a different path
# CHROMA_PERSIST_DIR=./chroma_db

# Sentence-transformer embedding model (used instead of Ollama all-minilm)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL=True

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=False


ADMIN_API_KEY=CareerGenie2026