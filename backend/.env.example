# Career Genie API Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ═══════════════════════════════════════════════════════════════
# LLM PROVIDERS
# ═══════════════════════════════════════════════════════════════

# Primary: Ollama (Local) - Recommended for development
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=all-minilm

# Fallback: Groq (Cloud)
GROQ_API_KEY=your_groq_api_key_here

# Fallback: Anthropic (Cloud)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fallback: Gemini (Cloud)
GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════════════════════
# JOB SEARCH
# ═══════════════════════════════════════════════════════════════

# SerpAPI for job search (get free key at https://serpapi.com)
SERPAPI_KEY=your_serpapi_key_here
# Alternative: SearchAPI
SEARCHAPI_KEY=

# ═══════════════════════════════════════════════════════════════
# SECURITY (Generate secure random values)
# ═══════════════════════════════════════════════════════════════

# JWT Secret - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string

# ═══════════════════════════════════════════════════════════════
# DATABASE (Optional - for production)
# ═══════════════════════════════════════════════════════════════

# PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Redis connection (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════

# Environment: development, staging, production
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60